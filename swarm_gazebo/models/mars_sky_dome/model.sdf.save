<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="mars_sky_dome">
    <static>true</static>

    <link name="link">
      <visual name="visual">
        <cast_shadows>false</cast_shadows>

        <geometry>
          <mesh>
            <uri>model://mars_sky_dome/meshes/mars_sky_dome.dae</uri>
          </mesh>
        </geometry>

        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>

          <pbr>
            <metal>
              <albedo_map>model://mars_sky_dome/meshes/mars_sky.png</albedo_map>
              <roughness>1.0</roughness>
              <metalness>0.0</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>
</sdf>