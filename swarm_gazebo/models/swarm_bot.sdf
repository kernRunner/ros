<?xml version="1.0"?>
<sdf version="1.8">
  <model name="swarm_bot">
    <pose>0 0 0.06 0 0 0</pose>

    <!--
      Enhanced alignment-debug version.

      Important visual conventions:
        - Green sphere  = exact chassis origin used by odom/controller
        - White line    = centerline of robot, x-axis direction
        - Red front     = front of robot
        - Blue rear     = rear of robot
        - Yellow side bars show true left/right width

      If green spheres line up but boxes look offset, the controller is aligned
      and the camera/body shape is misleading.
    -->

    <link name="chassis">
      <pose>0 0 0.06 0 0 0</pose>

      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.01</ixx>
          <iyy>0.02</iyy>
          <izz>0.03</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <!-- Main centered collision body -->
      <collision name="collision">
        <geometry>
          <box>
            <size>0.30 0.20 0.06</size>
          </box>
        </geometry>
      </collision>

      <!-- Main centered chassis body -->
      <visual name="visual_body">
        <geometry>
          <box>
            <size>0.30 0.20 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.20 0.20 0.25 1</ambient>
          <diffuse>0.25 0.25 0.30 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <!-- Exact controller/odom origin marker -->
      <visual name="origin_marker">
        <pose>0 0 0.105 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.032</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.0 1.0 0.0 1</ambient>
          <diffuse>0.0 1.0 0.0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>

      <!-- Long white centerline on top of the robot.
           This shows the actual x-axis/yaw direction. -->
      <visual name="top_centerline">
        <pose>0 0 0.096 0 0 0</pose>
        <geometry>
          <box>
            <size>0.31 0.012 0.008</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>

      <!-- Cross line through the origin.
           This makes sideways visual offsets obvious. -->
      <visual name="top_crossline">
        <pose>0 0 0.099 0 0 0</pose>
        <geometry>
          <box>
            <size>0.012 0.22 0.008</size>
          </box>
        </geometry>
        <material>
          <ambient>0.0 1.0 0.0 1</ambient>
          <diffuse>0.0 1.0 0.0 1</diffuse>
        </material>
      </visual>

      <!-- FRONT marker: red strip, centered across width -->
      <visual name="front_marker">
        <pose>0.145 0 0.095 0 0 0</pose>
        <geometry>
          <box>
            <size>0.025 0.20 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>0.90 0.05 0.05 1</ambient>
          <diffuse>1.00 0.10 0.10 1</diffuse>
        </material>
      </visual>

      <!-- BACK marker: blue strip, centered across width -->
      <visual name="rear_marker">
        <pose>-0.145 0 0.095 0 0 0</pose>
        <geometry>
          <box>
            <size>0.025 0.20 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.10 0.90 1</ambient>
          <diffuse>0.10 0.20 1.00 1</diffuse>
        </material>
      </visual>

      <!-- Front arrow head. It is symmetric in Y, so it should not look side-offset. -->
      <visual name="front_arrow_stem">
        <pose>0.175 0 0.097 0 0 0</pose>
        <geometry>
          <box>
            <size>0.050 0.045 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 0.55 0.0 1</ambient>
          <diffuse>1.0 0.65 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Left and right yellow side bars. These make true body width visible. -->
      <visual name="left_side_bar">
        <pose>0 0.105 0.092 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.010 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 0.9 0.0 1</ambient>
          <diffuse>1.0 0.9 0.0 1</diffuse>
        </material>
      </visual>

      <visual name="right_side_bar">
        <pose>0 -0.105 0.092 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.010 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 0.9 0.0 1</ambient>
          <diffuse>1.0 0.9 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Centered lidar housing.
           Moved from x=0.10 to x=0.0 so the robot no longer looks front-heavy.
           The sensor is also centered below. -->
      <visual name="lidar_visual">
        <pose>0 0 0.135 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.030</radius>
            <length>0.030</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.10 0.10 0.10 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>

      <visual name="lidar_cap">
        <pose>0 0 0.153 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.018</radius>
            <length>0.008</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.10 0.70 0.70 1</ambient>
          <diffuse>0.15 0.90 0.90 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>


      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0.135 0 0 0</pose>
        <update_rate>8</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>8.0</max>
            <resolution>0.02</resolution>
          </range>
        </ray>
        <always_on>1</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0 0.115 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0003</ixx>
          <iyy>0.0003</iyy>
          <izz>0.0003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>5.0</mu>
              <mu2>5.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0 -0.115 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0003</ixx>
          <iyy>0.0003</iyy>
          <izz>0.0003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>5.0</mu>
              <mu2>5.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Rear caster -->
    <link name="caster">
      <pose>-0.12 0 0.025 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00005</ixx>
          <iyy>0.00005</iyy>
          <izz>0.00005</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <sphere>
            <radius>0.025</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <sphere>
            <radius>0.025</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
    </link>

    <joint name="caster_joint" type="ball">
      <parent>chassis</parent>
      <child>caster</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.23</wheel_separation>
      <wheel_radius>0.05</wheel_radius>

      <frame_id>odom</frame_id>
      <child_frame_id>chassis</child_frame_id>

      <odom_publish_frequency>10</odom_publish_frequency>
    </plugin>
  </model>
</sdf>
