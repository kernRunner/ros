<?xml version="1.0"?>
<sdf version="1.8">
  <model name="swarm_bot_hex">
    <pose>0 0 0 0 0 0</pose>

    <link name="chassis">
      <pose>0 0 0.065 0 0 0</pose>

      <inertial>
        <mass>1.4</mass>
        <inertia>
          <ixx>0.014</ixx>
          <iyy>0.022</iyy>
          <izz>0.034</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.32 0.28 0.06</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual_body">
        <geometry>
          <polyline>
            <height>0.06</height>
            <point>0.18 0.00</point>
            <point>0.09 0.155</point>
            <point>-0.09 0.155</point>
            <point>-0.18 0.00</point>
            <point>-0.09 -0.155</point>
            <point>0.09 -0.155</point>
          </polyline>
        </geometry>
        <material>
          <ambient>0.20 0.20 0.25 1</ambient>
          <diffuse>0.25 0.25 0.30 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>

      <visual name="front_marker">
        <pose>0.165 0 0.04 0 0 0</pose>
        <geometry>
          <box>
            <size>0.030 0.12 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>0.90 0.05 0.05 1</ambient>
          <diffuse>1.00 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="top_center_marker">
        <pose>0 0 0.041 0 0 0</pose>
        <geometry>
          <box>
            <size>0.26 0.012 0.008</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="lidar_visual">
        <pose>0 0 0.085 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.026</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.10 0.10 0.10 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>

      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0.085 0 0 0</pose>
        <update_rate>4</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>180</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>8.0</max>
            <resolution>0.05</resolution>
          </range>
        </ray>
        <always_on>1</always_on>
        <visualize>false</visualize>
      </sensor>
      <visual name="lidar_3d_visual">
        <pose>0 0 0.145 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.032</radius>
            <length>0.030</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.20 0.20 1</ambient>
          <diffuse>0.05 0.45 0.45 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>

      <sensor name="lidar_3d" type="gpu_lidar">
        <pose>0 0 0.155 0 0 0</pose>
        <update_rate>2</update_rate>

        <ray>
          <scan>
            <horizontal>
              <samples>90</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>

            <vertical>
              <samples>6</samples>
              <resolution>1</resolution>
              <min_angle>-0.40</min_angle>
              <max_angle>0.30</max_angle>
            </vertical>
          </scan>

          <range>
            <min>0.25</min>
            <max>7.0</max>
            <resolution>0.05</resolution>
          </range>
        </ray>

        <always_on>1</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>

    <link name="left_front_wheel">
      <pose>0.09 0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.02</slip1>
              <slip2>0.02</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_rear_wheel">
      <pose>-0.09 0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.02</slip1>
              <slip2>0.02</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="right_front_wheel">
      <pose>0.09 -0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.02</slip1>
              <slip2>0.02</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="right_rear_wheel">
      <pose>-0.09 -0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.02</slip1>
              <slip2>0.02</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <joint name="left_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_front_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_rear_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_rear_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_front_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_rear_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_rear_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_front_wheel_joint</left_joint>
      <left_joint>left_rear_wheel_joint</left_joint>

      <right_joint>right_front_wheel_joint</right_joint>
      <right_joint>right_rear_wheel_joint</right_joint>

      <wheel_separation>0.33</wheel_separation>
      <wheel_radius>0.05</wheel_radius>

      <frame_id>odom</frame_id>
      <child_frame_id>chassis</child_frame_id>

      <odom_publish_frequency>5</odom_publish_frequency>
    </plugin>

  </model>
</sdf>