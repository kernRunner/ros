<?xml version="1.0"?>
<sdf version="1.8">
  <model name="swarm_bot">
    <pose>0 0 0.06 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <!-- Ultra-light relay-tree test model.
         Changes versus lidar model:
         - removed gpu_lidar sensor
         - removed lidar visual
         - removed wheel visuals
         - caster ball joint replaced by fixed joint
         - odom publish frequency reduced
         Keep this for relay-tree / return-home logic tests.
    -->

    <link name="chassis">
      <pose>0 0 0.06 0 0 0</pose>

      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.01</ixx>
          <iyy>0.02</iyy>
          <izz>0.03</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.30 0.20 0.06</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual_body">
        <geometry>
          <box>
            <size>0.30 0.20 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.20 0.20 0.25 1</ambient>
          <diffuse>0.25 0.25 0.30 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <!-- Small front marker only, for yaw/front direction. -->
      <visual name="front_marker">
        <pose>0.145 0 0.095 0 0 0</pose>
        <geometry>
          <box>
            <size>0.025 0.18 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>0.90 0.05 0.05 1</ambient>
          <diffuse>1.00 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>0 0.115 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>5.0</mu>
              <mu2>5.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="right_wheel">
      <pose>0 -0.115 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>5.0</mu>
              <mu2>5.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.05</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.05</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Fixed rear support: cheaper than a ball-joint caster. -->
    <link name="caster">
      <pose>-0.12 0 0.025 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>0.00003</ixx>
          <iyy>0.00003</iyy>
          <izz>0.00003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <sphere>
            <radius>0.020</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="caster_joint" type="fixed">
      <parent>chassis</parent>
      <child>caster</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.23</wheel_separation>
      <wheel_radius>0.05</wheel_radius>

      <frame_id>odom</frame_id>
      <child_frame_id>chassis</child_frame_id>

      <odom_publish_frequency>3</odom_publish_frequency>
    </plugin>
  </model>
</sdf>
