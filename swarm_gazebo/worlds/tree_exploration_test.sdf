<?xml version="1.0" ?>

<sdf version="1.8">
  <world name="tree_exploration_test">

    <gravity>0 0 -3.711</gravity>

    <physics name="stable_physics" type="ignored">
      <max_step_size>0.0025</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>400</real_time_update_rate>
    </physics>

    <plugin filename="ignition-gazebo-physics-system" name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system" name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="ignition::gazebo::systems::SceneBroadcaster"/>

    <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre</render_engine>
    </plugin>

    <scene>
      <ambient>0.36 0.26 0.20 1</ambient>
      <background>0.72 0.52 0.39 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="mars_sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.85 0.62 0.42 1</diffuse>
      <specular>0.03 0.025 0.02 1</specular>
      <direction>-0.45 0.25 -0.86</direction>
    </light>

    <!-- Mars terrain model -->
<!-- Mars terrain model -->
    <model name="mars_gale_crater_patch1">
      <static>true</static>

      <link name="link">

        <collision name="collision">
          <geometry>
            <mesh>
              <uri>model://mars_gale_crater_patch1/meshes/gale_crater_patch_final.stl</uri>
            </mesh>
          </geometry>
        </collision>

        <!-- Solid base terrain underneath the textured visual -->
        <visual name="base_color_visual">
          <cast_shadows>false</cast_shadows>
          <pose>0 0 -0.02 0 0 0</pose>

          <geometry>
            <mesh>
              <uri>model://mars_gale_crater_patch1/meshes/gale_crater_patch_final.stl</uri>
            </mesh>
          </geometry>

          <material>
            <ambient>0.45 0.28 0.16 1</ambient>
            <diffuse>0.45 0.28 0.16 1</diffuse>
            <specular>0 0 0 1</specular>
            <emissive>0.01 0.006 0.003 1</emissive>
          </material>
        </visual>

        <!-- Textured terrain on top -->
        <visual name="visual">
          <cast_shadows>true</cast_shadows>
          <pose>0 0 0.01 0 0 0</pose>

          <geometry>
            <mesh>
              <uri>model://mars_gale_crater_patch1/meshes/gale_crater_visual.dae</uri>
            </mesh>
          </geometry>

          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0 0 0 1</specular>
            <emissive>0 0 0 1</emissive>

            <pbr>
              <metal>
                <albedo_map>model://mars_gale_crater_patch1/materials/textures/red_laterite_soil_stones_diff_4k_8bit.png</albedo_map>
                <roughness>1.0</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>

        <!-- Tiny helper visual -->
        <visual name="keep_alive_visual">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry>
            <sphere>
              <radius>0.01</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0 0 0 1</specular>
            <emissive>1 1 1 1</emissive>
          </material>
        </visual>

      </link>
    </model>

    <!-- Rock / obstacle field -->
    <include>
      <uri>model://mars_rock_field</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- Sky dome background -->
    <include>
      <uri>model://mars_sky_dome</uri>
      <pose>0 0 0 0 0 1.5708</pose>
    </include>

  </world>
</sdf>