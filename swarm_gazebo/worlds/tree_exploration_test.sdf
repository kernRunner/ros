<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="tree_exploration_test">

    <physics name="1ms" type="ignored">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>5.0</real_time_factor>
    </physics>

    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.82 0.82 0.82 1</ambient>
            <diffuse>0.88 0.88 0.88 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Outer boundary -->
    <model name="outer_wall_north">
      <static>true</static>
      <pose>0 13 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>26 0.25 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>26 0.25 1</size></box></geometry></visual>
      </link>
    </model>

    <model name="outer_wall_south">
      <static>true</static>
      <pose>0 -13 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>26 0.25 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>26 0.25 1</size></box></geometry></visual>
      </link>
    </model>

    <model name="outer_wall_east">
      <static>true</static>
      <pose>13 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.25 26 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 26 1</size></box></geometry></visual>
      </link>
    </model>

    <model name="outer_wall_west">
      <static>true</static>
      <pose>-13 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.25 26 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 26 1</size></box></geometry></visual>
      </link>
    </model>


  </world>
</sdf>