              <near>0.1</near>
              <far>120.0</far>
            </clip>
          </camera>
        </sensor>
      </link>
    </model> -->

    <!-- Mars terrain model -->
    <model name="mars_gale_crater_patch1">
      <static>true</static>

      <link name="link">

      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://mars_gale_crater_patch1/meshes/gale_crater_patch_final.stl</uri>
          </mesh>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>3.0</mu>
              <mu2>3.0</mu2>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>

          <contact>
            <ode>
              <kp>1000000</kp>
              <kd>10</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>

        <!-- Solid base terrain underneath the textured visual because of unexpected flikering in the texture-->
        <visual name="base_color_visual">
          <cast_shadows>false</cast_shadows>
          <pose>0 0 -0.02 0 0 0</pose>

          <geometry>
            <mesh>
              <uri>model://mars_gale_crater_patch1/meshes/gale_crater_patch_final.stl</uri>
            </mesh>
          </geometry>

          <material>
            <ambient>0.45 0.28 0.16 1</ambient>
            <diffuse>0.45 0.28 0.16 1</diffuse>
            <specular>0 0 0 1</specular>
            <emissive>0.01 0.006 0.003 1</emissive>
          </material>
        </visual>

        <!-- Textured terrain -->
        <visual name="visual">
          <cast_shadows>true</cast_shadows>
          <pose>0 0 0.01 0 0 0</pose>

          <geometry>
            <mesh>
              <uri>model://mars_gale_crater_patch1/meshes/gale_crater_visual.dae</uri>
            </mesh>
          </geometry>

          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0 0 0 1</specular>
            <emissive>0 0 0 1</emissive>

            <pbr>
              <metal>
                <albedo_map>model://mars_gale_crater_patch1/materials/textures/red_laterite_soil_stones_diff_4k_8bit.png</albedo_map>
                <roughness>1.0</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>

      </link>
    </model>

    <!-- Sky dome background -->
    <include>
      <uri>model://mars_sky_dome</uri>
      <pose>0 0 0 0 0 1.5708</pose>
    </include>

  </world>
</sdf>