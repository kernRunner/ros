<?xml version="1.0" ?>

<sdf version="1.8">
  <world name="tree_exploration_test">

    <gravity>0 0 -3.711</gravity>

    <physics name="stable_physics" type="ignored">
      <max_step_size>0.0025</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>400</real_time_update_rate>
    </physics>

    <plugin filename="ignition-gazebo-physics-system" name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system" name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="ignition::gazebo::systems::SceneBroadcaster"/>

  
    <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre</render_engine>
    </plugin>

    <scene>
      <ambient>0.36 0.26 0.20 1</ambient>
      <background>0.72 0.52 0.39 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="mars_sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>

      <diffuse>0.85 0.62 0.42 1</diffuse>
      <specular>0.03 0.025 0.02 1</specular>

      <direction>-0.45 0.25 -0.86</direction>
    </light>

    <!-- OVERHEAD CAMERA -->
