<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="tree_exploration_test">

    <physics name="stable_physics" type="ignored">
      <max_step_size>0.003</max_step_size>
      <real_time_factor>3.0</real_time_factor>
    </physics>

    <plugin filename="ignition-gazebo-physics-system" name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system" name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light name="low_sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.95 0.86 0.72 1</diffuse>
      <specular>0.15 0.12 0.10 1</specular>
      <direction>-0.85 0.25 -0.45</direction>
    </light>

    <!-- Large open regolith ground: 200 m x 200 m -->
    <model name="regolith_ground">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.55 0.43 0.34 1</ambient>
            <diffuse>0.65 0.50 0.38 1</diffuse>
            <specular>0.05 0.04 0.03 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 180 m x 180 m open boundary. No internal obstacles. -->
    <model name="boundary_north">
      <static>true</static>
      <pose>0 90 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>180 0.25 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>180 0.25 1</size></box></geometry>
          <material>
            <ambient>0.22 0.18 0.15 1</ambient>
            <diffuse>0.32 0.25 0.20 1</diffuse>
            <specular>0.04 0.03 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="boundary_south">
      <static>true</static>
      <pose>0 -90 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>180 0.25 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>180 0.25 1</size></box></geometry>
          <material>
            <ambient>0.22 0.18 0.15 1</ambient>
            <diffuse>0.32 0.25 0.20 1</diffuse>
            <specular>0.04 0.03 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="boundary_east">
      <static>true</static>
      <pose>90 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 180 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 180 1</size></box></geometry>
          <material>
            <ambient>0.22 0.18 0.15 1</ambient>
            <diffuse>0.32 0.25 0.20 1</diffuse>
            <specular>0.04 0.03 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="boundary_west">
      <static>true</static>
      <pose>-90 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 180 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 180 1</size></box></geometry>
          <material>
            <ambient>0.22 0.18 0.15 1</ambient>
            <diffuse>0.32 0.25 0.20 1</diffuse>
            <specular>0.04 0.03 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
